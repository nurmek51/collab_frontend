// API Integration Guidelines  
const apiIntegrationGuidelines = `
1. Use ApiService singleton for consistent HTTP client configuration
2. Implement proper error handling for network requests
3. Use proper token management with TokenManager
4. Implement request/response interceptors for logging and auth
5. Handle authentication flows properly with refresh tokens
6. Use proper model classes for API responses with fromJson/toJson
7. Implement proper repository pattern for data layer
8. Cache API responses when appropriate
9. Handle offline scenarios gracefully
10. Use proper loading states and error states in UI
`;

// Routing Guidelines
const routingGuidelines = `
1. Use GoRouter for declarative routing with proper route names
2. Define route constants in AppRouter class for consistency
3. Use pageBuilder with SmoothPageTransition for unified smooth animations
4. Pass parameters via state.extra when needed (not query parameters)
5. Handle route parameters in pageBuilder using state.extra as appropriate type
6. Use proper route guards for authentication and authorization
7. Implement proper redirect logic in GoRouter redirect function
8. Use context.go() for navigation with proper route names
9. Handle deep linking and initial route properly
10. Test all navigation flows to ensure routes are properly configured
`;